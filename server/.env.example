# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=3000

# Postgres connection. Local dev: use docker-compose (see README) → this default works.
DATABASE_URL=postgres://sf:sf@localhost:5432/sydneyfishing

# Comma-separated list of allowed browser origins for the PWA (CORS).
# Dev: the static PWA served on 5500 (and 3000). Prod: https://your-domain.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Admin/moderator emails (comma-separated). These accounts can delete any forum post,
# review, or catch report. Set this to your own email to bootstrap the first moderator
# without editing the database. e.g. ADMIN_EMAILS=you@example.com
ADMIN_EMAILS=

# Secret used by @fastify/cookie. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In production the server REFUSES to boot with this dev default — set a strong value.
COOKIE_SECRET=change-me-to-a-long-random-string

# Cookie SameSite: "lax" works for same-site setups incl. api.domain <-> domain subdomains.
# Set "none" ONLY if the API is on a different registrable domain than the PWA (then it's
# also forced Secure). Leave as lax for the recommended api.<domain> layout.
COOKIE_SAMESITE=lax

# Proxy hops in front of the app (CloudFront/LB) for correct client IP in rate limiting.
# 0 = direct (dev), 1 = one proxy (typical prod behind CloudFront/Lightsail LB).
TRUST_PROXY_HOPS=0

# Canonical API base URL, used to build email verification links (avoids trusting Host header).
# e.g. https://api.your-domain
# PUBLIC_BASE_URL=

# Postgres TLS is auto-enabled in production / when DATABASE_URL has sslmode=require.
# Set true once you bundle the managed-DB CA for strict cert verification.
PGSSL_STRICT=false

# MVP toggle: require email verification before a user can post. Default off until SES is wired up.
REQUIRE_EMAIL_VERIFY=false

# ---- Feature flags (soft launch) ----
# Set a flag to "false" to disable that feature (endpoints not exposed + UI hidden).
# This branch DEFAULTS photos + email verification OFF for a cheap, low-risk soft launch
# (no image moderation / R2 / SES needed). Flip to "true" to re-enable when ready.
FEATURE_PHOTOS=false
FEATURE_EMAIL_VERIFY=false
FEATURE_CATCHES=true
FEATURE_REVIEWS=true
FEATURE_FORUM=true
FEATURE_INSIGHTS=true

# ---- Image storage ----
# local (default): store on disk, serve via /uploads. Fine for a single box / dev.
# s3: S3-compatible object storage. Use Cloudflare R2 (zero egress) for production.
STORAGE_DRIVER=local
# Only needed when STORAGE_DRIVER=s3 (R2 example):
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_BUCKET=sf-user-media
# S3_REGION=auto
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_PUBLIC_BASE=https://media.your-domain   # R2 public bucket URL or custom domain

# ---- Email (production) ----
# When set in production, the mailer sends via SES (see src/mailer.js). Unset = dev log only.
# SES_FROM=no-reply@your-domain
